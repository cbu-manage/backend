{
  "info": {
    "name": "스터디 모집 API",
    "description": "스터디 모집 전체 플로우 테스트\n\n순서: 1번부터 순서대로 실행\n\n테스트 계정:\n- 팀장: 1234567890 / test1234\n- 참가자: 1111222333 / test1234",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "var path = pm.request.url.path;",
          "if (path) {",
          "  var map = {",
          "    '{{postId}}': 'postId',",
          "    '{{groupId}}': 'groupId',",
          "    '{{groupMemberId}}': 'groupMemberId'",
          "  };",
          "  for (var i = 0; i < path.length; i++) {",
          "    if (map[path[i]]) {",
          "      var val = pm.collectionVariables.get(map[path[i]]);",
          "      if (val) path[i] = String(val);",
          "    }",
          "  }",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" }
  ],
  "item": [
    {
      "name": "1. 팀장 로그인",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentNumber\": 1234567890,\n  \"password\": \"test1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('로그인 성공', function() { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "2. 스터디 게시글 생성 (postId, groupId 자동저장)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"알고리즘 스터디 모집합니다\",\n  \"content\": \"주 2회 알고리즘 문제풀이를 함께할 팀원을 모집합니다.\",\n  \"studyTags\": [\"알고리즘\", \"코딩테스트\", \"Python\"],\n  \"studyName\": \"알고리즘 마스터\",\n  \"recruiting\": true,\n  \"maxMembers\": 4,\n  \"category\": 1\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/post/study", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study"] }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "var body = JSON.parse(pm.request.body.raw);",
              "body.studyName = body.studyName + '_' + Date.now();",
              "pm.request.body.raw = JSON.stringify(body);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.data) {",
              "  if (json.data.postId) pm.collectionVariables.set('postId', json.data.postId);",
              "  if (json.data.groupId) pm.collectionVariables.set('groupId', json.data.groupId);",
              "}",
              "pm.test('생성 성공', function() { pm.expect(json.code).to.eql('S-COMMON-CREATED'); });",
              "pm.test('작성자 기수/이름 포함', function() {",
              "  pm.expect(json.data).to.have.property('authorGeneration');",
              "  pm.expect(json.data).to.have.property('authorName');",
              "  pm.expect(json.data.authorGeneration).to.be.a('number');",
              "  pm.expect(json.data.authorName).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3. 스터디 목록 조회",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/post/study?page=0&size=10&category=1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "post", "study"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" },
            { "key": "category", "value": "1" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('목록 조회 성공', function() { pm.expect(json.code).to.eql('S-COMMON-SUCCESS'); });",
              "pm.test('목록 항목에 작성자 기수/이름 포함', function() {",
              "  if (json.data && json.data.content && json.data.content.length > 0) {",
              "    var item = json.data.content[0];",
              "    pm.expect(item).to.have.property('authorGeneration');",
              "    pm.expect(item).to.have.property('authorName');",
              "  }",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4. 스터디 상세 조회",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('상세 조회 성공', function() { pm.expect(json.code).to.eql('S-COMMON-SUCCESS'); });",
              "pm.test('상세 조회에 작성자 기수/이름 포함', function() {",
              "  pm.expect(json.data).to.have.property('authorGeneration');",
              "  pm.expect(json.data).to.have.property('authorName');",
              "  pm.expect(json.data.authorGeneration).to.be.a('number');",
              "  pm.expect(json.data.authorName).to.be.a('string');",
              "});",
              "pm.test('조회수 포함 및 1 이상', function() {",
              "  pm.expect(json.data).to.have.property('viewCount');",
              "  pm.expect(json.data.viewCount).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5. 내 스터디 목록",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/post/study/me?page=0&size=10&category=1",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "post", "study", "me"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" },
            { "key": "category", "value": "1" }
          ]
        }
      }
    },
    {
      "name": "6. 태그 필터 조회",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/v1/post/study/filter?page=0&size=10&tag=알고리즘",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "post", "study", "filter"],
          "query": [
            { "key": "page", "value": "0" },
            { "key": "size", "value": "10" },
            { "key": "tag", "value": "알고리즘" }
          ]
        }
      }
    },
    {
      "name": "7. 스터디 게시글 수정 (PATCH)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"[수정] 알고리즘 스터디 모집합니다\",\n  \"maxMembers\": 5\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}"] }
      }
    },
    {
      "name": "8. 참가자 로그인",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentNumber\": 1111222333,\n  \"password\": \"test1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('로그인 성공', function() { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "9. 그룹 가입 신청 (groupMemberId 자동저장)",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "members"] },
        "description": "참가자로 신청. 초기 상태 PENDING, groupMemberId 저장됨."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "if (json.data && json.data.groupMemberId) {",
              "  pm.collectionVariables.set('groupMemberId', json.data.groupMemberId);",
              "}",
              "pm.test('신청 성공', function() { pm.expect(json.code).to.eql('S-COMMON-CREATED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "10. 팀장 다시 로그인",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentNumber\": 1234567890,\n  \"password\": \"test1234\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/login", "host": ["{{baseUrl}}"], "path": ["api", "v1", "login"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('로그인 성공', function() { pm.response.to.have.status(200); });"
            ]
          }
        }
      ]
    },
    {
      "name": "11. 신청자 목록 조회 (팀장, GroupController)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/applicants", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "applicants"] },
        "description": "PENDING 신청자 목록 확인."
      }
    },
    {
      "name": "12. 신청 수락 (팀장, GroupController)",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"action\": \"ACCEPT\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/v1/groups/members/{{groupMemberId}}/applicant", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "members", "{{groupMemberId}}", "applicant"] },
        "description": "PENDING -> ACTIVE 처리."
      }
    },
    {
      "name": "13. 모집 마감",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}/close", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}", "close"] },
        "description": "PENDING 전원 거절 + 그룹 CLOSED. 12번에서 수락된 멤버가 있어야 성공."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('마감 성공', function() { pm.expect(json.code).to.eql('S-COMMON-UPDATED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "14. 마감 후 상세 조회 (recruiting=false 확인)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('마감 후 recruiting=false', function() {",
              "  pm.expect(json.data.recruiting).to.eql(false);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "15. 스터디 게시글 삭제 (soft delete)",
      "request": {
        "method": "DELETE",
        "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}"] },
        "description": "게시글 + 연결 그룹 함께 삭제 (soft delete)."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var json = pm.response.json();",
              "pm.test('삭제 성공', function() { pm.expect(json.code).to.eql('S-COMMON-DELETED'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "에러 케이스",
      "item": [
        {
          "name": "중복 가입 신청 (PENDING 상태에서 재신청 -> 409)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "members"] },
            "description": "참가자 로그인 상태에서 같은 그룹에 두 번 신청해보는 테스트입니다. 9번 실행 후에 해주세요. PENDING 상태에서는 409가 나와야 합니다."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('중복 신청 차단 (409)', function() { pm.response.to.have.status(409); });"
                ]
              }
            }
          ]
        },
        {
          "name": "거절 처리 (재신청 테스트용)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"REJECT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/groups/members/{{groupMemberId}}/applicant", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "members", "{{groupMemberId}}", "applicant"] },
            "description": "팀장 로그인 상태에서 실행. 순서: 9번 -> 10번 -> 여기서 거절 -> 8번(참가자 로그인) -> 다음. 12번 수락 전에 해야 함."
          }
        },
        {
          "name": "REJECTED 후 재신청 (재신청 성공 확인)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "members"] },
            "description": "참가자 로그인 후 실행. 거절 처리 스텝 다음에 해야 함. 재신청 시 PENDING으로 돌아오는지 확인."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.test('REJECTED 후 재신청 성공 (201)', function() { pm.response.to.have.status(201); });",
                  "pm.test('상태가 PENDING으로 복원됨', function() {",
                  "  pm.expect(json.data.groupMemberStatus).to.eql('PENDING');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "마감된 그룹에 가입 신청",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/members", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "members"] },
            "description": "참가자로 로그인 후, 이미 마감된 그룹에 신청해보는 테스트입니다. 13번(마감) 이후에 실행하세요"
          }
        },
        {
          "name": "이미 마감된 스터디 재마감",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}/close", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}", "close"] },
            "description": "팀장으로 로그인 후, 이미 마감한 스터디를 또 마감해보는 테스트입니다"
          }
        },
        {
          "name": "존재하지 않는 게시글 조회",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/post/study/9999", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "9999"] }
          }
        },
        {
          "name": "Validation - maxMembers=0",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"잘못된 스터디\",\n  \"content\": \"테스트\",\n  \"studyTags\": [\"test\"],\n  \"studyName\": \"테스트\",\n  \"recruiting\": true,\n  \"maxMembers\": 0,\n  \"category\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/post/study", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study"] },
            "description": "팀장 로그인 상태에서 실행해주세요. 최대인원 0명은 안 되니까 에러가 나야 합니다"
          }
        },
        {
          "name": "Validation - title 빈값",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"\",\n  \"content\": \"테스트\",\n  \"studyTags\": [\"test\"],\n  \"studyName\": \"테스트\",\n  \"recruiting\": true,\n  \"maxMembers\": 4,\n  \"category\": 1\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/post/study", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study"] },
            "description": "팀장 로그인 상태에서 실행해주세요. 제목이 빈칸이면 에러가 나야 합니다"
          }
        },
        {
          "name": "권한 없는 수정 (참가자 -> 팀장 게시글)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"해킹 시도\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}"] },
            "description": "참가자로 로그인한 채로 남의 게시글 수정을 시도합니다. 403이 나와야 정상이에요"
          }
        },
        {
          "name": "권한 없는 마감 (참가자 -> 마감 시도)",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/v1/post/study/{{postId}}/close", "host": ["{{baseUrl}}"], "path": ["api", "v1", "post", "study", "{{postId}}", "close"] },
            "description": "참가자로 로그인한 채로 마감을 시도합니다. 팀장만 가능해야 해요"
          }
        },
        {
          "name": "비팀장이 신청자 조회",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/v1/groups/{{groupId}}/applicants", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "{{groupId}}", "applicants"] },
            "description": "참가자로 로그인한 채로 신청자 목록을 조회합니다. 팀장만 가능해야 해요"
          }
        },
        {
          "name": "비팀장이 수락 시도",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ACCEPT\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/v1/groups/members/{{groupMemberId}}/applicant", "host": ["{{baseUrl}}"], "path": ["api", "v1", "groups", "members", "{{groupMemberId}}", "applicant"] },
            "description": "참가자로 로그인한 채로 신청 수락을 시도합니다. 팀장만 가능해야 해요"
          }
        },
        {
          "name": "수락자 없이 마감 시도",
